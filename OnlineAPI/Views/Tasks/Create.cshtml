@model Entities.TaskCreateViewModel
@{
    ViewData["Title"] = "Создать задачу";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Создать задачу - TaskFlow</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/taskboard.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        .loading {
            font-style: italic;
            color: #555;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="sidebar">
            <div class="logo">
                <h1><i class="fas fa-tasks"></i> <span>TaskFlow</span></h1>
            </div>
            <ul class="nav-menu">
                <li><a href="@Url.Action("Index", "Tasks")"><i class="fas fa-th-large"></i> <span>Доска</span></a></li>
                <li><a href="@Url.Action("Create", "Tasks", new { projectId = ViewBag.ProjectId })" class="active"><i class="fas fa-plus"></i> <span>Создать задачу</span></a></li>
            </ul>
        </div>

        <div class="main-content">
            <div class="top-bar">
                <div class="user-actions">
                    <div class="avatar">AK</div>
                </div>
            </div>

            <div class="board-header">
                <div class="board-title">
                    <h2>Создание новой задачи</h2>
                </div>
                <div class="board-actions">
                    <a href="@Url.Action("Index", "Tasks")" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Назад к доске</a>
                </div>
            </div>

            <div style="padding: 25px; max-width: 600px;">
                <form method="post" asp-action="Create" asp-controller="Tasks" class="task-form">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label asp-for="Title">Название задачи *</label>
                        <input asp-for="Title" class="form-control" placeholder="Введите название задачи" id="taskTitle" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description">Описание</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Опишите детали задачи" id="taskDescription"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Priority">Приоритет (AI Suggest)</label>
                        <div style="position: relative;">
                            <select asp-for="Priority" class="form-control" asp-items="Html.GetEnumSelectList<OnlineAPI.Entities.TaskPriority>()" id="taskPriority">
                            </select>
                            <span id="priorityLoading" class="loading" style="display:none; position: absolute; right: 10px; top: 50%; transform: translateY(-50%);">AI думает...</span>
                        </div>
                        <span asp-validation-for="Priority" class="text-danger"></span>
                    </div>

                    <div class="border rounded p-2" style="max-height: 250px; overflow-y: auto;">
                        @foreach (var user in Model.AvailableUsers)
                        {
                            <div class="form-check mb-1">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="SelectedUsers"
                                       value="@user.Value"
                                       id="user_@user.Value">
                                <label class="form-check-label"
                                       for="user_@user.Value">
                                    @user.Text
                                </label>
                            </div>
                        }
                    </div>

                    <input type="hidden" asp-for="ProjectID" value="@ViewBag.ProjectId" />

                    <div class="form-actions">
                        <a href="@Url.Action("Create", "Tasks", new { projectId = ViewBag.ProjectId })" class="btn btn-outline">Отмена</a>
                        <button type="submit" class="btn btn-primary">Создать задачу</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Debounce функция, чтобы не отправлять слишком часто запросы
        function debounce(func, wait) {
            let timeout;
            return function() {
                const context = this, args = arguments;
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(context, args), wait);
            };
        }

        // Маппинг AI-строки в числовое значение enum
        function mapPriorityToValue(priorityStr) {
            switch(priorityStr) {
                case "Low": return "0";
                case "Medium": return "1";
                case "High": return "2";
                default: return "";
            }
        }

        function predictPriority() {
            var title = $("#taskTitle").val().trim();
            var description = $("#taskDescription").val().trim();

            if (!title && !description) return;

            $("#priorityLoading").show(); 

            $.ajax({
                url: "http://localhost:8000/predict",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({ title: title, description: description }),
                success: function(response) {
                    var taskId = response.task_id;

                    // Polling для получения результата
                    var interval = setInterval(function() {
                        $.getJSON(`http://localhost:8000/predict/${taskId}`, function(result) {
                            if (result.priority) {
                                $("#taskPriority").val(mapPriorityToValue(result.priority));
                                $("#priorityLoading").hide();
                                clearInterval(interval);
                            }
                        }).fail(function(err) {
                            console.error("Ошибка получения AI результата:", err);
                            $("#priorityLoading").hide();
                            clearInterval(interval);
                        });
                    }, 1000);
                },
                error: function(err) {
                    console.error("Ошибка AI prediction:", err);
                    $("#priorityLoading").hide();
                }
            });
        }

        // Вешаем на ввод с дебаунсом 800ms
        $("#taskTitle, #taskDescription").on("input", debounce(predictPriority, 800));
    </script>
</body>
</html>